{
    "name": "task-tracker-api",
    "version": "1.0.0",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "test": "jest --coverage"
    },
    "dependencies": {
        "commander": "^14.0.3",
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "mariadb": "^3.3.0"
    },
    "devDependencies": {
        "@babel/core": "^7.29.7",
        "@babel/preset-env": "^7.29.7",
        "babel-jest": "^29.0.0",
        "jest": "^29.0.0",
        "nodemon": "^3.1.0",
        "supertest": "^7.0.0"
    },
    "jest": {
        "testEnvironment": "node",
        "transformIgnorePatterns": [
            "/node_modules/(?!(mariadb)/)"
        ],
        "coverageThreshold": {
            "global": {
                "lines": 40,
                "functions": 40,
                "branches": 40,
                "statements": 40
            }
        },
        "coverageReporters": [
            "text",
            "lcov",
            "html"
        ]
    }
}
